# Server Configuration
PORT=3000
NODE_ENV=development

# Security - REQUIRED IN PRODUCTION
# Generate a strong secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production

# CORS Configuration (comma-separated list)
# In development, typically just http://localhost:3000
# In production, list your actual domain(s)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_PATH=./delicious.db

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# Email (SMTP) — required for welcome and password reset emails
# Leave blank in development to log emails to console instead
# Gmail example: host=smtp.gmail.com, port=587, user=you@gmail.com, pass=app-password
# Resend example: host=smtp.resend.com, port=587, user=resend, pass=re_xxxxx
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Public URL used in email links
BASE_URL=https://onlylinks.id

# From name shown in emails
EMAIL_FROM_NAME=OnlyLinks
